---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="logo">GRADD</span>
        <p>
          Groupe de Recherche Appliquée au Développement Durable.<br />
          Cabinet d'études et de conseil en politiques publiques,
          ancré dans les réalités locales du Sénégal.
        </p>
      </div>

      <div class="footer-col">
        <h4>Navigation</h4>
        <ul>
          <li><a href="/">Accueil</a></li>
          <li><a href="/qui-sommes-nous">Qui sommes-nous ?</a></li>
          <li><a href="/domaines-competences">Compétences</a></li>
          <li><a href="/methodologie">Méthodologie</a></li>
          <li><a href="/actions">Actions</a></li>
          <li><a href="/ressources">Ressources</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:contact@gradd.sn">contact@gradd.sn</a></li>
          <li>Dakar, Sénégal</li>
          <li>Lun – Ven, 9h – 17h</li>
        </ul>
        <h4 style="margin-top: var(--space-6);">Références</h4>
        <ul>
          <li><a href="https://www.ansd.sn/" target="_blank" rel="noopener">ANSD Sénégal</a></li>
          <li><a href="https://ipar.sn/" target="_blank" rel="noopener">IPAR</a></li>
          <li><a href="https://www.undp.org/fr/senegal" target="_blank" rel="noopener">PNUD Sénégal</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} GRADD — Tous droits réservés</p>
      <div style="display:flex; gap: var(--space-6);">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/sitemap.xml">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
