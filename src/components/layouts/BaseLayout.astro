---
export const prerender = true;

import "../../styles/variables.css";
import "../../styles/base.css";
import "../../styles/layout.css";
import "../../styles/global.css";
import "../../styles/home.css";

import Header from "../Header.astro";
import Footer from "../Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  pageType?: "website" | "article";
  jsonLd?: object;
}

const SITE_URL = "https://gradd.sn";
const SITE_NAME = "GRADD — Études & Conseil au Sénégal";

const {
  title = "GRADD — Cabinet d'études en sciences sociales et développement durable | Sénégal",
  description = "GRADD est un cabinet sénégalais d'études et de conseil spécialisé en évaluation de politiques publiques, suivi-évaluation, recherche appliquée et développement durable en Afrique de l'Ouest.",
  canonical = Astro.url.pathname,
  ogImage = "/images/enquete_ecv.jpg",
  pageType = "website",
  jsonLd,
} = Astro.props;

const canonicalURL = `${SITE_URL}${canonical}`;
const ogImageURL = `${SITE_URL}${ogImage}`;

// JSON-LD par défaut : Organization
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${SITE_URL}/#organisation`,
  "name": "GRADD",
  "legalName": "Groupe de Recherche Appliquée au Développement Durable",
  "url": SITE_URL,
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Dakar",
    "addressCountry": "SN"
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Sénégal"
  },
  "serviceType": [
    "Études sociologiques",
    "Suivi-évaluation",
    "Évaluation de politiques publiques",
    "Recherche appliquée",
    "Développement durable"
  ],
  "sameAs": []
};

const finalJsonLd = jsonLd ?? defaultJsonLd;
const titleSuffix = title.includes("GRADD") ? "" : " | GRADD";
const fullTitle = `${title}${titleSuffix}`;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO fondamental -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="GRADD — Groupe de Recherche Appliquée au Développement Durable" />
    <meta name="language" content="fr" />
    <meta name="geo.region" content="SN" />
    <meta name="geo.placename" content="Dakar, Sénégal" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_SN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Keywords ciblés -->
    <meta name="keywords" content="cabinet études Sénégal, suivi-évaluation Afrique de l'Ouest, évaluation politiques publiques, recherche appliquée développement durable, sociologie Dakar, études sociologiques Sénégal, GRADD, bureau études développement, ODD Sénégal" />

    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD Données structurées -->
    <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />
  </head>

  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
