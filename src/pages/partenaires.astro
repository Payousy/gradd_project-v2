---
import BaseLayout from "../components/layouts/BaseLayout.astro";

// === DONNÉES INSTITUTIONNELLES ===
const categories = [
  {
    id: "recherche",
    label: "Recherche en sciences sociales",
    description: "Institutions académiques et centres de recherche dont les travaux structurent notre discipline.",
    links: [
      {
        name: "CODESRIA",
        longName: "Conseil pour le développement de la recherche en sciences sociales en Afrique",
        url: "https://codesria.org/fr/",
        location: "Dakar, Sénégal",
        desc: "La principale institution panafricaine dédiée à la recherche en sciences sociales, dont le siège est à Dakar. Réseau de chercheurs, publications scientifiques et programmes de formation.",
        tag: "Sciences sociales"
      },
      {
        name: "IRD",
        longName: "Institut de Recherche pour le Développement",
        url: "https://www.ird.fr",
        location: "France / Présence Sénégal",
        desc: "Organisme public français de recherche scientifique actif en Afrique subsaharienne, notamment au Sénégal, sur les sciences sociales, la santé et l'environnement.",
        tag: "Recherche interdisciplinaire"
      },
      {
        name: "UCAD",
        longName: "Université Cheikh Anta Diop de Dakar",
        url: "https://www.ucad.sn",
        location: "Dakar, Sénégal",
        desc: "La principale université sénégalaise, pôle académique central et vivier des sciences humaines et sociales en Afrique de l'Ouest francophone.",
        tag: "Université"
      },
      {
        name: "IPAR",
        longName: "Initiative Prospective Agricole et Rurale",
        url: "https://www.ipar.sn",
        location: "Dakar, Sénégal",
        desc: "Think tank sénégalais spécialisé dans les politiques agricoles, rurales et alimentaires en Afrique de l'Ouest. Recherches sur la gouvernance foncière et les dynamiques rurales.",
        tag: "Agriculture & Territoire"
      },
      {
        name: "CIRAD",
        longName: "Centre de coopération internationale en recherche agronomique pour le développement",
        url: "https://www.cirad.fr",
        location: "France / Afrique de l'Ouest",
        desc: "Organisme de recherche français sur les sciences du vivant et sociales appliquées à l'agriculture tropicale et au développement durable.",
        tag: "Agriculture & Développement"
      },
    ]
  },
  {
    id: "multilateral",
    label: "Organisations multilatérales & Nations Unies",
    description: "Partenaires techniques et financiers multilatéraux actifs dans les politiques de développement au Sénégal.",
    links: [
      {
        name: "PNUD Sénégal",
        longName: "Programme des Nations Unies pour le Développement",
        url: "https://www.undp.org/fr/senegal",
        location: "Dakar, Sénégal",
        desc: "Le PNUD accompagne le Sénégal dans ses efforts de développement durable, réduction de la pauvreté, gouvernance et résilience climatique.",
        tag: "Nations Unies"
      },
      {
        name: "Banque mondiale – Sénégal",
        longName: "Groupe de la Banque mondiale",
        url: "https://www.banquemondiale.org/fr/country/senegal",
        location: "Washington / Dakar",
        desc: "La Banque mondiale finance et évalue des programmes de développement au Sénégal dans les domaines de l'éducation, la santé, l'agriculture et les infrastructures.",
        tag: "Financement & Évaluation"
      },
      {
        name: "UNICEF Sénégal",
        longName: "Fonds des Nations Unies pour l'enfance",
        url: "https://www.unicef.org/senegal/",
        location: "Dakar, Sénégal",
        desc: "L'UNICEF intervient sur la protection de l'enfance, la santé, l'éducation et la nutrition, et mobilise régulièrement des bureaux d'études pour ses évaluations de programme.",
        tag: "Nations Unies"
      },
      {
        name: "UNCDF Sénégal",
        longName: "Fonds des Nations Unies pour le développement du capital",
        url: "https://www.uncdf.org/fr/senegal",
        location: "Dakar, Sénégal",
        desc: "L'UNCDF est présent au Sénégal depuis 1981, spécialisé dans le financement du développement local, la décentralisation et l'inclusion financière.",
        tag: "Développement local"
      },
      {
        name: "FAO – Bureau Sénégal",
        longName: "Organisation des Nations Unies pour l'alimentation et l'agriculture",
        url: "https://www.fao.org/senegal/fr/",
        location: "Dakar, Sénégal",
        desc: "La FAO appuie les politiques agricoles et alimentaires au Sénégal et conduit des études de sécurité alimentaire et de développement rural.",
        tag: "Agriculture & Sécurité alimentaire"
      },
    ]
  },
  {
    id: "bilateral",
    label: "Coopération bilatérale",
    description: "Agences de coopération internationale dont les programmes au Sénégal mobilisent régulièrement des compétences en études et évaluation.",
    links: [
      {
        name: "AFD – Sénégal",
        longName: "Agence Française de Développement",
        url: "https://www.afd.fr/fr/page-region-pays/senegal",
        location: "Dakar, Sénégal",
        desc: "Partenaire historique du Sénégal, l'AFD finance des projets dans l'agriculture, les infrastructures, l'éducation et l'environnement. Elle mandate régulièrement des évaluations indépendantes.",
        tag: "Coopération française"
      },
      {
        name: "USAID Sénégal",
        longName: "United States Agency for International Development",
        url: "https://www.usaid.gov/senegal",
        location: "Dakar, Sénégal",
        desc: "L'USAID finance de nombreux programmes de santé, agriculture et gouvernance au Sénégal avec des exigences d'évaluation rigoureuses (MEL).",
        tag: "Coopération américaine"
      },
      {
        name: "GIZ Sénégal",
        longName: "Deutsche Gesellschaft für Internationale Zusammenarbeit",
        url: "https://www.giz.de/en/worldwide/352.html",
        location: "Dakar, Sénégal",
        desc: "Agence de coopération allemande qui met en œuvre des projets de développement rural, de formation professionnelle et de bonne gouvernance au Sénégal.",
        tag: "Coopération allemande"
      },
      {
        name: "UE – Délégation au Sénégal",
        longName: "Délégation de l'Union européenne au Sénégal",
        url: "https://www.eeas.europa.eu/delegations/senegal_fr",
        location: "Dakar, Sénégal",
        desc: "La délégation européenne coordonne les programmes de coopération au développement de l'UE au Sénégal dans les domaines de la gouvernance, la santé et le développement rural.",
        tag: "Coopération européenne"
      },
    ]
  },
  {
    id: "senegal",
    label: "Institutions sénégalaises",
    description: "Acteurs publics et institutionnels sénégalais qui structurent les politiques nationales de développement.",
    links: [
      {
        name: "DPEE",
        longName: "Direction de la Planification et des Études Économiques – Sénégal",
        url: "https://www.dpee.sn",
        location: "Dakar, Sénégal",
        desc: "La DPEE assure la planification économique nationale, produit des études et analyses stratégiques pour orienter les politiques publiques.",
        tag: "Planification publique"
      },
      {
        name: "ANSD",
        longName: "Agence Nationale de la Statistique et de la Démographie",
        url: "https://www.ansd.sn",
        location: "Dakar, Sénégal",
        desc: "Principale source de données statistiques officielles au Sénégal : enquêtes nationales, recensements, données socio-économiques. Référence incontournable pour les études terrain.",
        tag: "Données & Statistiques"
      },
      {
        name: "Plan Sénégal Émergent (PSE)",
        longName: "Plan de développement économique et social du Sénégal",
        url: "https://www.pse.sn",
        location: "Dakar, Sénégal",
        desc: "Cadre de référence des politiques publiques sénégalaises à moyen et long terme. Toute étude d'impact doit s'inscrire dans ses axes stratégiques.",
        tag: "Politique nationale"
      },
      {
        name: "ENDA Tiers Monde",
        longName: "Environnement et Développement du Tiers Monde",
        url: "https://www.enda.sn",
        location: "Dakar, Sénégal",
        desc: "ONG de recherche-action fondée en 1972, l'une des plus anciennes structures africaines de développement communautaire et d'études sociales appliquées.",
        tag: "Recherche-action"
      },
    ]
  },
  {
    id: "methodologie",
    label: "Évaluation & Méthodologie",
    description: "Réseaux et ressources de référence pour les professionnels de l'évaluation et du suivi des politiques publiques.",
    links: [
      {
        name: "EVAL-Sénégal",
        longName: "Réseau sénégalais de suivi-évaluation",
        url: "https://www.idev.afdb.org",
        location: "Sénégal / Afrique de l'Ouest",
        desc: "Réseau professionnel des évaluateurs au Sénégal. Partage de pratiques, standards éthiques et renforcement des capacités en évaluation.",
        tag: "Suivi-évaluation"
      },
      {
        name: "IDEAS (BAD)",
        longName: "Département de l'évaluation indépendante – Banque africaine de développement",
        url: "https://www.idev.afdb.org/fr/page/accueil-0",
        location: "Abidjan / Pan-africain",
        desc: "L'unité d'évaluation indépendante de la BAD publie des méthodologies, guides et rapports d'évaluation de référence pour les politiques de développement africaines.",
        tag: "Évaluation indépendante"
      },
      {
        name: "3ie",
        longName: "International Initiative for Impact Evaluation",
        url: "https://www.3ieimpact.org",
        location: "International",
        desc: "Référence mondiale en évaluation d'impact rigoureux des programmes de développement. Propose des synthèses de données probantes et des standards méthodologiques.",
        tag: "Évaluation d'impact"
      },
      {
        name: "OCDE – CAD",
        longName: "Comité d'Aide au Développement de l'OCDE",
        url: "https://www.oecd.org/dac/evaluation/",
        location: "Paris / International",
        desc: "Le CAD de l'OCDE définit les standards mondiaux d'évaluation de l'aide au développement (critères DAC). Référence obligatoire pour tout dispositif d'évaluation sérieux.",
        tag: "Standards & Normes"
      },
    ]
  },
];
---

<BaseLayout
  title="Partenaires & Ressources institutionnelles — GRADD"
  description="Institutions, organisations et ressources de référence dans les domaines de la recherche en sciences sociales, du développement et de l'évaluation des politiques publiques en Afrique de l'Ouest."
  canonical="/partenaires"
>
  <div class="page-intro">
    <div class="container">
      <span class="section-eyebrow">Liens utiles</span>
      <h1>Partenaires & Ressources institutionnelles</h1>
      <div class="gold-divider"></div>
      <p class="section-lead">
        GRADD s'inscrit dans un écosystème riche d'institutions de recherche,
        d'organisations multilatérales et d'acteurs nationaux. Cette page
        regroupe les ressources et partenaires de référence de notre secteur.
      </p>
    </div>
  </div>

  {categories.map((cat, ci) => (
    <section class={`section ${ci % 2 === 0 ? "section--white" : "section--bg"} section--sm`}>
      <div class="container">
        <div class="section-intro fade-up">
          <span class="section-eyebrow">{String(ci + 1).padStart(2, "0")}</span>
          <h2 class="section-title">{cat.label}</h2>
          <div class="gold-divider"></div>
          <p class="section-lead">{cat.description}</p>
        </div>

        <div class="partners-grid fade-up">
          {cat.links.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="partner-card"
              aria-label={`Visiter le site de ${link.name} — ${link.longName}`}
            >
              <div class="partner-card-header">
                <div>
                  <span class="partner-name">{link.name}</span>
                  <span class="partner-tag">{link.tag}</span>
                </div>
                <span class="partner-arrow" aria-hidden="true">↗</span>
              </div>
              <p class="partner-longname">{link.longName}</p>
              <p class="partner-desc">{link.desc}</p>
              <span class="partner-location">📍 {link.location}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="cta-section">
    <div class="container">
      <h2>Vous êtes une institution partenaire ?</h2>
      <p>Contactez-nous pour discuter d'une collaboration ou d'un partenariat de recherche.</p>
      <a href="/contact" class="btn btn-primary" style="background-color: var(--color-gold); border-color: var(--color-gold); color: var(--color-navy)">
        Prendre contact
      </a>
    </div>
  </section>
</BaseLayout>

<style>
.partners-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-6);
  margin-top: var(--space-8);
}

.partner-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: var(--space-6);
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-top: 3px solid var(--color-gold);
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  text-decoration: none;
  transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  color: inherit;
}

.partner-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(13, 43, 62, 0.1);
  text-decoration: none;
}

.partner-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-3);
}

.partner-name {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-xl);
  color: var(--color-navy);
  line-height: 1.1;
  margin-bottom: var(--space-1);
}

.partner-tag {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gold);
  background: var(--color-gold-light);
  padding: 2px 8px;
  border-radius: 2px;
}

.partner-arrow {
  font-size: var(--text-xl);
  color: var(--color-border);
  flex-shrink: 0;
  transition: color var(--transition-fast), transform var(--transition-fast);
}

.partner-card:hover .partner-arrow {
  color: var(--color-navy);
  transform: translate(2px, -2px);
}

.partner-longname {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--color-blue-mid);
  text-transform: uppercase;
  margin: 0;
}

.partner-desc {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.partner-location {
  font-size: var(--text-xs);
  color: var(--color-muted);
  margin-top: auto;
}

@media (max-width: 600px) {
  .partners-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add("visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll(".fade-up").forEach(el => observer.observe(el));
</script>
