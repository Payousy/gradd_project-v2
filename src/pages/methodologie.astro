---
import BaseLayout from "../components/layouts/BaseLayout.astro";

const steps = [
  {
    n: "01",
    title: "Diagnostic et cadrage",
    desc: "Analyse du contexte social, institutionnel et territorial. Identification des parties prenantes, des enjeux et des besoins afin de définir un cadre d'intervention précis et partagé avec le commanditaire.",
    detail: "Entretiens exploratoires, revue documentaire, cartographie des acteurs."
  },
  {
    n: "02",
    title: "Collecte et production des données",
    desc: "Mobilisation d'outils qualitatifs et quantitatifs adaptés aux objectifs : enquêtes par questionnaire, entretiens semi-directifs, focus groups, observations ethnographiques, exploitation de bases de données existantes.",
    detail: "Combinaison de méthodes pour une triangulation robuste des données."
  },
  {
    n: "03",
    title: "Analyse et co-construction",
    desc: "Traitement et analyse rigoureuse des données collectées. Restitution intermédiaire auprès des acteurs concernés pour ajustements, validation et appropriation des résultats.",
    detail: "Analyse thématique, statistique descriptive, ateliers de restitution."
  },
  {
    n: "04",
    title: "Recommandations et accompagnement",
    desc: "Formulation de recommandations opérationnelles spécifiques aux enjeux identifiés. Appui à la mise en œuvre et au suivi des préconisations auprès des équipes du commanditaire.",
    detail: "Rapport final, note de synthèse, ateliers d'appropriation."
  },
];
---

<BaseLayout
  title="Méthodologie — GRADD"
  description="Découvrez la méthodologie d'intervention du GRADD : une approche en 4 étapes rigoureuses, ancrée dans les sciences sociales."
>
  <div class="page-intro">
    <div class="container">
      <span class="section-eyebrow">Notre approche</span>
      <h1>Méthodologie d'intervention</h1>
      <div class="gold-divider"></div>
      <p class="section-lead">
        Une approche structurée, issue des sciences sociales, garantissant
        la cohérence des analyses et l'opérationnalité des recommandations —
        adaptée à chaque contexte d'intervention.
      </p>
    </div>
  </div>

  <section class="section section--white">
    <div class="container">
      <div style="display: grid; gap: var(--space-8);">
        {steps.map((step, i) => (
          <div style={`display: grid; grid-template-columns: 80px 1fr; gap: var(--space-8); align-items: start; padding: var(--space-8); border: 1px solid var(--color-border); border-left: 3px solid var(--color-gold); border-radius: 0 var(--radius-md) var(--radius-md) 0; background: var(--color-white);`}>
            <div style="text-align: center;">
              <span style="font-family: var(--font-display); font-size: 3rem; color: var(--color-gold-light); line-height: 1; display: block;">{step.n}</span>
            </div>
            <div>
              <h3 style="margin-bottom: var(--space-3);">{step.title}</h3>
              <p style="margin-bottom: var(--space-3);">{step.desc}</p>
              <p style="font-size: var(--text-sm); color: var(--color-blue-mid); font-style: italic; margin: 0;">↳ {step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="grid-2" style="gap: var(--space-12); align-items: center;">
        <div>
          <span class="section-eyebrow">Notre posture</span>
          <h2 class="section-title">Participatif et pluridisciplinaire</h2>
          <div class="gold-divider"></div>
          <p>
            GRADD privilégie des approches participatives qui intègrent les parties
            prenantes à toutes les étapes du cycle de projet — de l'analyse initiale
            à l'évaluation finale.
          </p>
          <p>
            La pluridisciplinarité est au cœur de notre démarche : sociologie,
            économie du développement, géographie territoriale et sciences politiques
            se croisent pour produire des analyses complètes et nuancées.
          </p>
        </div>
        <div>
          <img
            src="/images/abrit_provisoire_sedhiou.jpg"
            alt="Travail de terrain à Sédhiou"
            style="border-radius: var(--radius-lg); width: 100%; height: 320px; object-fit: cover;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Discutons de votre projet</h2>
      <p>Chaque mission est construite sur mesure. Contactez-nous pour échanger.</p>
      <a href="/contact" class="btn btn-primary" style="background-color: var(--color-gold); border-color: var(--color-gold); color: var(--color-navy)">
        Nous contacter
      </a>
    </div>
  </section>
</BaseLayout>
