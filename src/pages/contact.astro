---
import BaseLayout from "../components/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — GRADD"
  description="Contactez GRADD pour vos projets de recherche appliquée, suivi-évaluation et développement durable."
>
  <div class="page-intro">
    <div class="container">
      <span class="section-eyebrow">Échangeons</span>
      <h1>Nous contacter</h1>
      <div class="gold-divider"></div>
      <p class="section-lead">
        Vous avez un projet ou une question ? Remplissez le formulaire
        ci-dessous et nous vous répondrons rapidement.
      </p>
    </div>
  </div>

  <section class="section section--white">
    <div class="container">
      <div class="contact-grid">
        <!-- Formulaire -->
        <div class="contact-form-wrapper">
          <form
            name="contact"
            method="POST"
            class="contact-form"
            data-netlify="true"
            action="/merci"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-group">
              <label for="name">Nom complet *</label>
              <input type="text" id="name" name="name" required autocomplete="name" placeholder="Votre nom" />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="votre@email.com" />
            </div>

            <div class="form-group">
              <label for="organisation">Organisation</label>
              <input type="text" id="organisation" name="organisation" placeholder="Votre structure" />
            </div>

            <div class="form-group">
              <label for="subject">Sujet</label>
              <input type="text" id="subject" name="subject" placeholder="Objet de votre demande" />
            </div>

            <div class="form-group">
              <label for="message">Message *</label>
              <textarea id="message" name="message" required rows="6" placeholder="Décrivez votre projet ou votre question..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Envoyer le message</button>
          </form>
        </div>

        <!-- Infos -->
        <div class="contact-info">
          <div class="info-block">
            <h3>Email</h3>
            <p><a href="mailto:contact@gradd.sn">contact@gradd.sn</a></p>
          </div>

          <div class="info-block">
            <h3>Adresse</h3>
            <p>GRADD<br />Dakar, Sénégal</p>
          </div>

          <div class="info-block">
            <h3>Disponibilité</h3>
            <p>Lundi — Vendredi<br />9h00 – 17h00 (GMT)</p>
          </div>

          <div class="info-block">
            <h3>Interventions</h3>
            <p>Sénégal et Afrique de l'Ouest</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: var(--space-12);
  align-items: start;
}

@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr; }
}

.contact-form-wrapper {
  background: var(--color-bg);
  padding: var(--space-8);
  border-radius: var(--radius-md);
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.form-group label {
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--color-text);
}

.form-group input,
.form-group textarea {
  padding: 0.75rem 1rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-base);
  font-size: var(--text-base);
  background: var(--color-white);
  color: var(--color-text);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--color-navy);
  box-shadow: 0 0 0 3px rgba(13, 43, 62, 0.08);
}

.contact-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.info-block {
  padding: var(--space-6);
  border-left: 3px solid var(--color-gold);
  background: var(--color-white);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  border: 1px solid var(--color-border);
  border-left: 3px solid var(--color-gold);
}

.info-block h3 {
  font-family: var(--font-base);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: var(--space-2);
}

.info-block p {
  margin: 0;
  font-size: var(--text-sm);
  color: var(--color-muted);
}

.info-block a {
  color: var(--color-navy);
  font-weight: 600;
}
</style>
